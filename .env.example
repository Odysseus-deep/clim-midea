# Copy this file to .env and fill in the values for YOUR unit:
#   cp .env.example .env
#
# Get IP / id / token / key with:   .venv/bin/msmart-ng discover
# (once; token and key only apply to "V3" devices).

AC_IP=192.168.1.42          # the AC's local IP on your LAN
AC_ID=123456789012345       # device id (from `msmart-ng discover`)
AC_TOKEN=                    # V3 token (V3 devices only)
AC_KEY=                      # V3 key   (V3 devices only)

# --- Optional ----------------------------------------------------------------
# Put the SQLite database somewhere else (e.g. an SSD). Falls back to a local
# file if the volume isn't mounted.
# AC_DB_PATH=/Volumes/my-ssd/clim/clim.db

# Sun-height overlay on the temperature chart (optional). Your rough location.
# AC_LAT=48.8566
# AC_LON=2.3522

# HomeKit bridge (on by default). Set AC_HOMEKIT=0 to disable it.
# CHANGE the pairing code before any real deployment.
# AC_HOMEKIT=1
# AC_HOMEKIT_PIN=123-45-678
# AC_HOMEKIT_PORT=51826
