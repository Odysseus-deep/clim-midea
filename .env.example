# Copy this file to .env and fill in the values for YOUR unit:
#   cp .env.example .env
#
# Get IP / id / token / key with:   .venv/bin/msmart-ng discover
# (once; token and key only apply to "V3" devices).

AC_IP=192.168.1.42          # the AC's local IP on your LAN
AC_ID=123456789012345       # device id (from `msmart-ng discover`)
AC_TOKEN=                    # V3 token (V3 devices only)
AC_KEY=                      # V3 key   (V3 devices only)

# --- Optional ----------------------------------------------------------------
# Put the SQLite database somewhere else (e.g. an SSD). Falls back to a local
# file if the volume isn't mounted.
# AC_DB_PATH=/Volumes/my-ssd/clim/clim.db

# Sun-height overlay and weather forecast on the temperature chart (optional).
# Your rough location. The forecast uses Open-Meteo (no key). AROME (Meteo-France)
# is the default model, great over France; set AC_WX_MODEL=best_match elsewhere.
# AC_LAT=48.8566
# AC_LON=2.3522
# AC_WX_MODEL=arome_france_hd

# Autopilot (optional, off by default; also toggleable from the dashboard). The AC's
# own setpoint is the ceiling: it keeps the room under it, turning the AC fully off
# when it is cool enough (silent, ~0 W, still reports temp), and starting to cool
# ahead of forecast heat. Lead time comes from the room's measured cooling rate (per
# fan speed) and the AROME forecast, de-biased against the actually measured outdoor.
# Backs off for PAUSE seconds after any manual command, so it never fights you.
# AC_AUTOPILOT=1
# AC_AP_PAUSE=3600          # ignore autopilot this long after a manual command
# AC_AP_HYST=0.5            # room must exceed the setpoint by this to cool
# AC_AP_STAYON_MARGIN=3.0   # room lags outdoor by ~this (insulation)
# AC_AP_LOOKAHEAD=4.0       # forecast window for the decision, hours

# Sensor calibration (default 0). Some return-air sensors read off the occupied room
# (they sit in the recirculated airflow near the coil). If yours does, measure the gap
# with a STABILIZED air probe (a thermocouple takes a moment to settle; surfaces and
# cheap thermometers mislead) and set the offset. Added for the autopilot decision and
# the displayed curve, not to the logged sample (kept raw); it cancels in the rates.
# AC_INDOOR_OFFSET=0.0

# HomeKit bridge (on by default). Set AC_HOMEKIT=0 to disable it.
# CHANGE the pairing code before any real deployment.
# AC_HOMEKIT=1
# AC_HOMEKIT_PIN=123-45-678
# AC_HOMEKIT_PORT=51826
